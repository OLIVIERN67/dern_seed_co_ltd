# DERN SEED Frontend — Environment Variables
# Copy this file to .env (or .env.production for production builds).

# Backend API base URL.
# - Development: leave EMPTY — the Vite dev server proxies /api to http://localhost:8000.
# - Production (same origin, reverse proxy routes /api to backend): leave EMPTY.
# - Production (backend on a different origin): set the full URL, e.g. https://api.dernseed.com
VITE_API_BASE_URL=

# Dev-only: override the backend target used by the Vite proxy (default http://localhost:8000)
VITE_DEV_API_TARGET=http://localhost:8000

# Google Analytics 4 measurement ID (optional). Analytics is disabled when empty.
# Example: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# WhatsApp business number in international format, digits only (optional).
# Used by the floating WhatsApp button and contact links.
VITE_WHATSAPP_NUMBER=250782724840
