# Copy to .env and update values

APP_ENV=development
APP_URL=http://localhost:8000

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=dern_seed
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Security
# Must be a long random string
SESSION_SECRET=change-me-to-a-long-random-secret

# Session lifetime (seconds)
SESSION_TTL=2592000

# If true, cookies will be marked Secure (HTTPS only)
SESSION_COOKIE_SECURE=false

# Cookie name
SESSION_COOKIE_NAME=dern_session

